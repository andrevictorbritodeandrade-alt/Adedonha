{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "type": { "type": "string", "description": "Account type: 'google' or 'email'" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "type", "createdAt"]
    },
    "AccessLog": {
      "title": "AccessLog",
      "description": "Records a user login/access event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "type": { "type": "string", "description": "Login type" },
        "ip": { "type": "string", "description": "IP Address" },
        "location": { "type": "string", "description": "City/Country" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Access timestamp" }
      },
      "required": ["userId", "email", "type", "ip", "location", "timestamp"]
    },
    "NDA": {
      "title": "NDA",
      "description": "Records NDA acceptance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Acceptance timestamp" }
      },
      "required": ["userId", "email", "timestamp"]
    },
    "Game": {
      "title": "Game",
      "description": "Represents a game in the menu.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The display name of the game." },
        "subtitle": { "type": "string", "description": "A short description or category." },
        "image_url": { "type": "string", "description": "URL of the game's avatar image." },
        "path": { "type": "string", "description": "The internal path or ID for navigation." },
        "accent_color": { "type": "string", "description": "The primary color for the game tile (e.g., #00FF00)." }
      },
      "required": ["title", "subtitle", "image_url", "path", "accent_color"]
    },
    "VermelhinhoScore": {
      "title": "VermelhinhoScore",
      "description": "Leaderboard entry for Onde está o Vermelhinho.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "score": { "type": "number" },
        "time": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "score", "time", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/accessLogs/{logId}": {
      "schema": { "$ref": "AccessLog" },
      "description": "History of user access"
    },
    "/registros_nda/{logId}": {
      "schema": { "$ref": "NDA" },
      "description": "NDA acceptance logs"
    },
    "/games/{gameId}": {
      "schema": { "$ref": "Game" },
      "description": "Dynamic game menu items"
    },
    "/vermelhinho_scores/{scoreId}": {
      "schema": { "$ref": "VermelhinhoScore" },
      "description": "Leaderboard for Vermelhinho game"
    }
  }
}
