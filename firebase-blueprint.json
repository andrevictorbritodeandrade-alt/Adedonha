{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "type": { "type": "string", "description": "Account type: 'google' or 'email'" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "type", "createdAt"]
    },
    "AccessLog": {
      "title": "AccessLog",
      "description": "Records a user login/access event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "type": { "type": "string", "description": "Login type" },
        "ip": { "type": "string", "description": "IP Address" },
        "location": { "type": "string", "description": "City/Country" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Access timestamp" }
      },
      "required": ["userId", "email", "type", "ip", "location", "timestamp"]
    },
    "NDA": {
      "title": "NDA",
      "description": "Records NDA acceptance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Acceptance timestamp" }
      },
      "required": ["userId", "email", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/accessLogs/{logId}": {
      "schema": { "$ref": "AccessLog" },
      "description": "History of user access"
    },
    "/registros_nda/{logId}": {
      "schema": { "$ref": "NDA" },
      "description": "NDA acceptance logs"
    }
  }
}
