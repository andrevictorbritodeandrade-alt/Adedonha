rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "andrevictorbritodeandrade@gmail.com";
    }

    // Data Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'type', 'createdAt']) &&
             data.uid is string && data.uid.size() < 100 &&
             data.email is string && data.email.size() < 255 &&
             data.type is string && data.type.size() < 20;
    }
    function isValidAccessLog(data) {
      return data.keys().hasAll(['userId', 'email', 'type', 'ip', 'location', 'timestamp']) &&
             data.userId is string && data.userId.size() < 100 &&
             data.email is string && data.email.size() < 255 &&
             data.type is string && data.type.size() < 20 &&
             data.ip is string && data.ip.size() < 50 &&
             data.location is string && data.location.size() < 255;
    }
    function isValidNDA(data) {
      return data.keys().hasAll(['userId', 'email', 'timestamp']) &&
             data.userId is string && data.userId.size() < 100 &&
             data.email is string && data.email.size() < 255;
    }
    function isValidGame(data) {
      return data.keys().hasAll(['title', 'subtitle', 'image_url', 'path', 'accent_color']) &&
             data.title is string && data.title.size() < 100 &&
             data.subtitle is string && data.subtitle.size() < 255 &&
             data.image_url is string && data.image_url.size() < 1000 &&
             data.path is string && data.path.size() < 100 &&
             data.accent_color is string && data.accent_color.size() < 20;
    }

    function isValidVermelhinhoScore(data) {
      return data.keys().hasAll(['uid', 'name', 'score', 'time', 'difficulty', 'location', 'date']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() < 100 &&
             data.score is number && data.score >= 0 &&
             data.time is number && data.time >= 0 &&
             data.difficulty is string &&
             data.location is string &&
             data.date is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAccessLog(request.resource.data);
    }

    match /registros_nda/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidNDA(request.resource.data);
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /vermelhinho_scores/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidVermelhinhoScore(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /artifacts/{appId}/public/data/leaderboard/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Needs hardening based on business logic
    }
  }
}
